Shader "Hidden/lilToonLite"
{
    Properties
    {
        lilProperties "DefaultLite"
        lilProperties "DefaultOpaque"
    }
    HLSLINCLUDE
        #define LIL_RENDER 0
    ENDHLSL


    lilPassShaderName "Hidden/ltspass_lite_opaque"
    lilSubShaderTags {"RenderType" = "Opaque" "Queue" = "Geometry"}
    lilSubShaderURP "DefaultLiteDirect"

    CustomEditor "*LIL_EDITOR_NAME*"
}