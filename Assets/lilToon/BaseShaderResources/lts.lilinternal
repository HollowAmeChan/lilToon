Shader "lilToon"
{
    Properties
    {
        lilProperties "Default"
        lilProperties "DefaultOpaque"
    }
    HLSLINCLUDE
        #define LIL_RENDER 0
    ENDHLSL


    lilPassShaderName "Hidden/ltspass_opaque"
    lilSubShaderTags {"RenderType" = "Opaque" "Queue" = "Geometry"}
    lilSubShaderURP "DefaultDirect"

    CustomEditor "*LIL_EDITOR_NAME*"
}