Shader "_lil/[Optional] lilToonFurOnlyCutout"
{
    Properties
    {
        lilProperties "Default"
        lilProperties "DefaultFurCutout"
    }
    HLSLINCLUDE
        #define LIL_RENDER 1
    ENDHLSL


    lilPassShaderName "Hidden/lilToonFurCutout"
    lilSubShaderTags {"RenderType" = "TransparentCutout" "Queue" = "AlphaTest"}
    lilSubShaderURP "DefaultDirectFurOnly"

    CustomEditor "*LIL_EDITOR_NAME*"
}