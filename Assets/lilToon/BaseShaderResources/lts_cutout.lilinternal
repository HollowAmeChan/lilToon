Shader "Hidden/lilToonCutout"
{
    Properties
    {
        lilProperties "Default"
        lilProperties "DefaultCutout"
    }
    HLSLINCLUDE
        #define LIL_RENDER 1
    ENDHLSL


    lilPassShaderName "Hidden/ltspass_cutout"
    lilSubShaderTags {"RenderType" = "TransparentCutout" "Queue" = "AlphaTest"}
    lilSubShaderURP "DefaultDirect"

    CustomEditor "*LIL_EDITOR_NAME*"
}